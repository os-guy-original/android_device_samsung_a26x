/dev/block/by-name/vendor_boot u:object_r:vendor_boot_block_device:s0

# VBMETA partitions
/dev/block/by-name/vbmeta        u:object_r:vbmeta_block_device:s0
/dev/block/by-name/vbmeta_system u:object_r:vbmeta_system_block_device:s0

# Metadata partition
/metadata(/.*)?               u:object_r:metadata_file:s0
/dev/block/by-name/metadata   u:object_r:metadata_file:s0

# Cache partition
/cache(/.*)?                  u:object_r:cache_file:s0
/dev/block/by-name/cache      u:object_r:cache_file:s0

# Keystorage partition
/keystorage(/.*)?             u:object_r:keystorage_file:s0
