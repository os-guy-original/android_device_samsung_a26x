# HARX partition
/harx(/.*)?                   u:object_r:harx_file:s0
/dev/block/by-name/harx       u:object_r:harx_file:s0

# Misc partition
/dev/block/by-name/misc       u:object_r:misc_block_device:s0

# Vendor firmware
/vendor/firmware(/.*)?        u:object_r:vendor_firmware_file:s0

# Keymaster/keymint data
/data/vendor/keymaster(/.*)?  u:object_r:keymaster_data_file:s0

# Fingerprint data
/data/vendor/fingerprint(/.*)? u:object_r:fingerprint_data_file:s0

# GNSS/GPS data
/data/vendor/gnss(/.*)?       u:object_r:gnss_data_file:s0

# Sensor data
/data/vendor/sensors(/.*)?    u:object_r:sensor_data_file:s0

# NFC data
/data/vendor/nfc(/.*)?        u:object_r:nfc_data_file:s0

# Widevine DRM data
/data/vendor/widevine(/.*)?   u:object_r:widevine_data_file:s0

