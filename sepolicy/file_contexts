# EFS partitions - use existing efs_file from AOSP
/sec_efs(/.*)?                u:object_r:sec_efs_file:s0

# Samsung-specific partitions
/mnt/vendor/param(/.*)?       u:object_r:param_file:s0
/optics(/.*)?                 u:object_r:optics_file:s0
/prism(/.*)?                  u:object_r:prism_file:s0

