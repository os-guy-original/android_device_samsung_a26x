/cpefs(/.*)?                  u:object_r:cpefs_file:s0

# Persistent partition
/mnt/vendor/persist(/.*)?     u:object_r:persist_file:s0

# Camera firmware
/vendor/firmware/camera(/.*)? u:object_r:camera_fw_file:s0

# Bluetooth firmware
/vendor/firmware/bt(/.*)?     u:object_r:bt_firmware_file:s0

