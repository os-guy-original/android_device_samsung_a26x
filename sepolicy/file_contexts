/data/vendor/health(/.*)?     u:object_r:health_data_file:s0

# USB configuration
/vendor/etc/usb(/.*)?         u:object_r:usb_config_file:s0

# Samsung sysfs paths
/sys/devices/platform/soc/([0-9a-f])+/gearm(/.*)?    u:object_r:sysfs_samsung:s0
/sys/devices/platform/soc/([0-9a-f])+/gsensor(/.*)?  u:object_r:sysfs_sensors:s0

# EFS mount point
/mnt/vendor/efs(/.*)?         u:object_r:efs_file:s0

# CPEFS mount point
/mnt/vendor/cpefs(/.*)?       u:object_r:cpefs_file:s0
