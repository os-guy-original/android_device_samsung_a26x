# ============================================================
# AxionOS Performance Init Rules
# ============================================================

# Allow init to access VM dirty page and cache pressure proc nodes
allow init proc_dirty:file rw_file_perms;
allow init proc_drop_caches:file rw_file_perms;
allow init proc_dirty_ratio:file rw_file_perms;
allow init proc_sched:file rw_file_perms;

# Allow init to access GPU frequency nodes for boost framework
allow init sysfs_gpu:file rw_file_perms;
