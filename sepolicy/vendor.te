# =============================================================================
# Partition Permissions
# =============================================================================
# Allow init to access boot partitions
allow init boot_block_device:blk_file { open read getattr };
allow init recovery_block_device:blk_file { open read getattr };
allow init dtbo_block_device:blk_file { open read getattr };
allow init init_boot_block_device:blk_file { open read getattr };
allow init vendor_boot_block_device:blk_file { open read getattr };
allow init vbmeta_block_device:blk_file { open read getattr };
allow init vbmeta_system_block_device:blk_file { open read getattr };
allow init metadata_file:dir { create read write open add_name remove_name search };
allow init metadata_file:file { create read write open getattr setattr unlink };
allow init keystorage_file:dir { create read write open add_name remove_name search };
allow init keystorage_file:file { create read write open getattr setattr unlink };
allow init harx_file:dir { create read write open add_name remove_name search };
allow init harx_file:file { create read write open getattr setattr unlink };
allow init misc_block_device:blk_file { open read write getattr };

