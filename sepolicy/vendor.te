# Additional Samsung service domains
type vendor_tzdaemon, domain;
type vendor_tzts_daemon, domain;
type vendor_vaultkeeperd, domain;
type vendor_hermesd, domain;
type vendor_wlbtd, domain;
type vendor_epic, domain;
type vendor_dmd, domain;
type vendor_memlogd, domain;
type vendor_mlgcat, domain;
type vendor_cass, domain;
type vendor_iod, domain;
type vendor_wtasd, domain;
type vendor_wvkprov, domain;

# Samsung health HAL
type hal_samsung_health_default, domain;

# Samsung thermal HAL  
type hal_samsung_thermal_default, domain;

# Samsung vibrator HAL
type hal_samsung_vibrator_default, domain;

# Samsung WiFi HAL
type hal_samsung_wifi_default, domain;

# Allow Samsung services to run

# Samsung secure execution environment

# Allow access to tee devices
allow vendor_tzdaemon tee_device:chr_file { open read write ioctl };
allow vendor_tzdaemon tee_data_file:dir { create read write open add_name remove_name search };
allow vendor_tzdaemon tee_data_file:file { create read write open getattr setattr unlink };
