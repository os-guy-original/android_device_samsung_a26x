# Rootdir scripts (exclude install-recovery.sh - not needed for VAB)
PRODUCT_PACKAGES += \
    gps.sh \
    enable_test_mode.sh \
    hdm_status.sh \
    init.insmod.sh \
    mx_log_collection.sh \
    mx_logger.sh \
    mx_logger_dump.sh

# Init files
PRODUCT_PACKAGES += \
    fstab.s5e8835 \
    fstab.ramplus \
    init.recovery.s5e8835.rc \
    init.recovery.samsung.rc \
    init.s5e8835.rc

# Ramdisk fstab (for first-stage init)
PRODUCT_COPY_FILES += \
    $(LOCAL_PATH)/rootdir/etc/fstab.ramplus:$(TARGET_COPY_OUT_RAMDISK)/fstab.ramplus

# Samsung-specific configurations
PRODUCT_PACKAGES += \
    SamsungDoze \
    lineage.health-service.samsung

# Soong namespaces
PRODUCT_SOONG_NAMESPACES += \
    $(LOCAL_PATH)

# Inherit the proprietary files
$(call inherit-product, vendor/samsung/a26x/a26x-vendor.mk)
