    <hal format="aidl">
        <name>vendor.samsung.hardware.gnss</name>
        <version>3</version>
        <fqname>ISehGnss/default</fqname>
    </hal>
    <hal format="aidl">
        <name>vendor.samsung.hardware.health</name>
        <fqname>ISehHealth/default</fqname>
    </hal>
    <hal format="aidl">
        <name>vendor.samsung.hardware.keymint</name>
        <version>2</version>
