    </hal>
    <hal format="aidl">
        <name>vendor.samsung.hardware.keymint</name>
        <version>2</version>
        <fqname>ISehKeyMintFactory/default</fqname>
    </hal>
    <hal format="hidl">
        <name>vendor.samsung.hardware.nfc</name>
        <transport>hwbinder</transport>
        <fqname>@2.0::ISehNfc/default</fqname>
