<compatibility-matrix version="1.0" type="framework" level="202504">
    <!-- AOSP HALs not in default FCM at this level -->
    <hal format="aidl">
        <name>android.hardware.security.rkp</name>
        <version>3</version>
        <interface>
            <name>IRemotelyProvisionedComponent</name>
            <instance>default</instance>
        </interface>
    </hal>
    <hal format="aidl">
        <name>android.hardware.cas</name>
        <interface>
            <name>IMediaCasService</name>
            <instance>default</instance>
        </interface>
    </hal>

    <!-- Samsung Custom HALs are provided by vendor blobs, not built from source -->
    <!-- Commenting out to avoid VINTF build errors -->
    <!--
    <hal format="hidl">
        <name>vendor.samsung.hardware.audio</name>
        <version>1.0</version>
        <interface>
            <name>ISehDevicesFactory</name>
            <instance>default</instance>
        </interface>
    </hal>
    -->
    <!-- All other Samsung HALs commented out - they're in vendor blobs -->
</compatibility-matrix>
