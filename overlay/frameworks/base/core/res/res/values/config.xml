<resources>
    <!-- Flag indicating whether the we should enable the automatic brightness in Settings. -->
    <bool name="config_automatic_brightness_available">true</bool>

    <!-- Screen brightness used to dim the screen when the user activity timeout expires.
         Range is 1 to 255. -->
    <integer name="config_screenBrightnessDim">6</integer>

    <!-- Default screen brightness, from 0 to 255. 57/665 * 255 ≈ 22 -->
    <integer name="config_screenBrightnessSettingDefault">22</integer>

    <!-- Maximum screen brightness, from 0 to 255.
         The stock backlight driver uses 0-665. We scale that to 0-255. -->
    <integer name="config_screenBrightnessSettingMaximum">255</integer>

    <!-- Minimum screen brightness -->
    <integer name="config_screenBrightnessSettingMinimum">1</integer>

    <!-- The path to the backlight sysfs file
         (used by HALs that write brightness themselves) -->
    <string name="config_backlightNode">/sys/class/backlight/panel/brightness</string>

    <!-- Maximum HWC backlight range - must match the real driver max (665) -->
    <integer name="config_screenBrightnessBacklightHwaMax">665</integer>

    <!-- Is the battery LED intrusive? Used to decide if there should be a disable option -->
    <bool name="config_intrusiveBatteryLed">false</bool>

    <!-- Does the battery LED support multiple colors? -->
    <bool name="config_multiColorBatteryLed">false</bool>

    <!-- Control whether the always on display mode is available. This should only be
         enabled on devices where the display has been tuned to be power efficient in DOZE. -->
    <bool name="config_dozeAlwaysOnDisplayAvailable">true</bool>

    <!-- Control whether the always on display mode is enabled by default. -->
    <bool name="config_dozeAlwaysOnEnabled">false</bool>

    <!-- Doze component -->
    <string name="config_dozeComponent">com.android.systemui/com.android.systemui.doze.DozeService</string>

    <!-- If true, the doze component is not started until after the screen has been turned off -->
    <bool name="config_dozeAfterScreenOffByDefault">true</bool>

    <!-- Display dimensions: SM-A266B has 1080x2340, 90Hz AMOLED panel -->
    <integer name="config_screenWidth">1080</integer>
    <integer name="config_screenHeight">2340</integer>

    <!-- Rounded corner radius (in pixels, from the display mode node) -->
    <dimen name="rounded_corner_radius">48dp</dimen>

    <!-- Safe headphone volume index -->
    <integer name="config_safe_media_volume_index">8</integer>

    <!-- Battery capacity in mAh - verified from dmesg FCC value -->
    <integer name="config_battery_capacity">5000</integer>

    <!-- Flag specifying whether VoLTE is available on device (verified from logcat) -->
    <bool name="config_device_volte_available">true</bool>

    <!-- Flag specifying whether VT is available on device -->
    <bool name="config_device_vt_available">true</bool>

    <!-- Flag specifying whether WFC over IMS is available on device -->
    <bool name="config_device_wfc_ims_available">true</bool>

    <!-- Whether the device supports Carrier Aggregation (verified from radio logcat) -->
    <bool name="config_lteUsingCarrierAggregation">true</bool>

    <!-- Operating voltage for Bluetooth controller (S5E8835 platform, 3.3V) -->
    <integer name="config_bluetooth_operating_voltage_mv">3300</integer>

    <!-- Does the system support navigation keys? -->
    <bool name="config_supportSystemNavigationKeys">true</bool>

    <!-- Supports sustained performance mode? (based on Cortex-A78 big cores) -->
    <bool name="config_sustainedPerformanceModeSupported">true</bool>

    <!-- Haptic/vibration intensity defaults -->
    <integer name="config_defaultHapticFeedbackIntensity">2</integer>
    <integer name="config_defaultNotificationVibrationIntensity">2</integer>
    <integer name="config_defaultRingVibrationIntensity">2</integer>

</resources>
